# ==============================================================================
# CONFIGURAÇÃO GERAL
# ==============================================================================
# IMPORTANTE: Substitua 'X.X.X.X' em TODOS os lugares abaixo pelo IP PÚBLICO da EC2 ou 'localhost'
EC2_PUBLIC_IP=98.86.150.125

# ==============================================================================
# BACKEND (API)
# ==============================================================================
PORT=3001
ENV=staging
ALLOWED_ORIGINS=http://98.86.150.125:3000,http://localhost:3000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=cava_user
DB_PASSWORD=cava_password_dev
DB_NAME=cava_db

# Storage (MinIO)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minio_access_key
STORAGE_SECRET_KEY=minio_secret_key
STORAGE_BUCKET=cava-media
STORAGE_USE_SSL=false
# URL pública para o navegador acessar imagens.
# Se estiver rodando local, seria http://localhost:9000/cava-media
# Na EC2, deve ser http://IP_DA_EC2:9000/cava-media
STORAGE_PUBLIC_URL=http://98.86.150.125:9000/cava-media

# JWT
JWT_SECRET=sua_chave_secreta_super_segura_para_staging
JWT_EXPIRATION=24h
JWT_ACCESS_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h

# Security
# Must be at least 32 characters
PASSWORD_PEPPER=your-password-pepper-never-change-after-production
CSRF_SECRET=staging-csrf-secret-key-at-least-32-chars-long-secure-random
BCRYPT_COST=12

# Wizard AI (Se houver)
OPENAI_API_KEY=sua_chave_openai_aqui

# ==============================================================================
# FRONTEND (Next.js)
# ==============================================================================
# URL da API acessível pelo NAVEGADOR do usuário (Client-side)
NEXT_PUBLIC_API_URL=http://98.86.150.125:3001

# NextAuth / Auth.js (se estiver usando)
NEXTAUTH_URL=http://98.86.150.125:3000
NEXTAUTH_SECRET=sua_chave_secreta_nextauth_staging
